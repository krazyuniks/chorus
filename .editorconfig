# EditorConfig — https://editorconfig.org
# Keeps whitespace and line-ending rules consistent across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,ts,tsx,js,jsx,css,scss,md,mdx,html,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[justfile]
indent_style = space
indent_size = 4
