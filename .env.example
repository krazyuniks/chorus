# Chorus — environment overrides for the local stack.
#
# Copy to `.env` and adjust values as needed:
#
#   cp .env.example .env
#
# Every variable is read by `compose.yml` (or `scripts/dc`) using
# `${VAR:-default}` style, so unset values fall back to sensible defaults.
# Defaults match the documented runtime in `docs/architecture.md` and the
# ports in `AGENTS.md`.

# =============================================================================
# Host user mapping
# =============================================================================
# Bind-mounted volumes are chowned to UID:GID by the chown-init service so
# files created inside containers stay owned by your host user. `scripts/dc`
# exports these from `id -u` / `id -g` automatically.

UID=1000
GID=1000

# =============================================================================
# Postgres (Chorus application database)
# =============================================================================

CHORUS_PG_USER=chorus
CHORUS_PG_PASSWORD=chorus
CHORUS_PG_DB=chorus
CHORUS_PG_PORT=5432
CHORUS_PG_IMAGE=postgres:17-alpine

# =============================================================================
# Redpanda (Kafka API + Schema Registry + Console)
# =============================================================================

REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:latest
REDPANDA_KAFKA_PORT=9092
REDPANDA_SCHEMA_REGISTRY_PORT=8081
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_IMAGE=docker.redpanda.com/redpandadata/console:latest
REDPANDA_CONSOLE_PORT=8080

# =============================================================================
# Temporal (durable orchestration) + dedicated Postgres
# =============================================================================

TEMPORAL_IMAGE=temporalio/auto-setup:latest
TEMPORAL_PORT=7233
TEMPORAL_UI_IMAGE=temporalio/ui:latest
TEMPORAL_UI_PORT=8233

TEMPORAL_PG_IMAGE=postgres:17-alpine
TEMPORAL_PG_USER=temporal
TEMPORAL_PG_PASSWORD=temporal
TEMPORAL_PG_DB=temporal

# =============================================================================
# Mailpit (SMTP capture for the lead-intake demo)
# =============================================================================

MAILPIT_IMAGE=axllent/mailpit:latest
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# =============================================================================
# Grafana (operational dashboards)
# =============================================================================

GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=chorus

# =============================================================================
# OpenTelemetry collector
# =============================================================================

OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:latest
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# =============================================================================
# Application services (Phase 1A wires these in)
# =============================================================================
# Defaults follow the documented stack: BFF on 8000, frontend on 5173.

BFF_PORT=8000
FRONTEND_PORT=5173
