{
  "annotations": {"list": []},
  "description": "Outbox depth, oldest pending event age, and retry attempts for the Workstream A relay. Use these panels to spot stuck or failing rows before they back up the projection.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pending outbox rows",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "postgres", "uid": "chorus-postgres"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 250}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "chorus-postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM outbox_events WHERE status = 'pending' AND tenant_id LIKE '$tenant'"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oldest pending age (s)",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "postgres", "uid": "chorus-postgres"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 300}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "chorus-postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(EXTRACT(EPOCH FROM (now() - MIN(occurred_at)))::int, 0) AS value FROM outbox_events WHERE status = 'pending' AND tenant_id LIKE '$tenant'"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed outbox rows",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "postgres", "uid": "chorus-postgres"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "chorus-postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM outbox_events WHERE status = 'failed' AND tenant_id LIKE '$tenant'"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox status mix",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 6},
      "datasource": {"type": "postgres", "uid": "chorus-postgres"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {"custom": {"drawStyle": "line", "stacking": {"mode": "normal"}, "fillOpacity": 25}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "chorus-postgres"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', occurred_at) AS time, status AS metric, COUNT(*)::int AS value FROM outbox_events WHERE tenant_id LIKE '$tenant' AND $__timeFilter(occurred_at) GROUP BY time, metric ORDER BY time"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Failing rows (last_error)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 15},
      "datasource": {"type": "postgres", "uid": "chorus-postgres"},
      "options": {"showHeader": true},
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "chorus-postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT occurred_at, tenant_id, correlation_id, workflow_id, event_type, status, attempts, next_attempt_at, last_error FROM outbox_events WHERE status IN ('failed','publishing') AND tenant_id LIKE '$tenant' ORDER BY occurred_at DESC LIMIT 100"
        }
      ]
    }
  ],
  "preload": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["chorus", "phase-1a", "projection"],
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "chorus-postgres"},
        "query": "SELECT tenant_id FROM tenants ORDER BY tenant_id",
        "refresh": 1,
        "includeAll": true,
        "allValue": "%",
        "current": {"text": "All", "value": "%"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Chorus / Projection lag",
  "uid": "chorus-projection-lag",
  "version": 1,
  "weekStart": ""
}
