#!/usr/bin/env zsh
# scripts/dc — docker compose wrapper for Chorus.
#
# Sources `.env` if present and exports UID/GID from the host so bind-mount
# ownership stays consistent across host and containers. Use this everywhere
# in place of bare `docker compose`; the justfile routes through it.

set -euo pipefail

SCRIPT_DIR="${0:A:h}"
REPO_ROOT="${SCRIPT_DIR:h}"

if [[ -f "$REPO_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$REPO_ROOT/.env"
    set +a
fi

export UID="$(id -u)"
export GID="$(id -g)"

exec docker compose --project-directory "$REPO_ROOT" "$@"
