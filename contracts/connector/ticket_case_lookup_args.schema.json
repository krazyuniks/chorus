{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/ticket_case_lookup_args.schema.json",
  "title": "TicketCaseLookupArgs",
  "description": "Contract-only arguments for future local ticket case lookup using safe refs and bounded lookup policy fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_ref",
    "account_ref",
    "lookup_policy_ref"
  ],
  "properties": {
    "case_ref": {
      "type": "string",
      "pattern": "^case_[A-Za-z0-9_-]+$"
    },
    "request_ref": {
      "type": "string",
      "pattern": "^req_[A-Za-z0-9_-]+$"
    },
    "account_ref": {
      "type": "string",
      "pattern": "^acct_[A-Za-z0-9_-]+$"
    },
    "product_ref": {
      "type": "string",
      "pattern": "^prod_[A-Za-z0-9_-]+$"
    },
    "lookup_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    },
    "include_history_category": {
      "type": "string",
      "enum": [
        "current_status_only",
        "bounded_recent_status_refs"
      ]
    }
  }
}
