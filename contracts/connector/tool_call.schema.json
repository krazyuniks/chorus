{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/tool_call.schema.json",
  "title": "ToolCall",
  "description": "Structured request from the Agent Runtime to the Tool Gateway.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_call_id",
    "invocation_id",
    "tenant_id",
    "correlation_id",
    "agent_id",
    "tool_name",
    "mode",
    "idempotency_key",
    "arguments",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tool_call_id": {
      "type": "string",
      "format": "uuid"
    },
    "invocation_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "enum": [
        "calendar.lookup_availability",
        "calendar.propose_hold",
        "calendar.create_hold",
        "calendar.cancel_hold",
        "crm.route_to_quoting_queue",
        "referral_inbox.route",
        "decline_ledger.route",
        "outbound_comms.message",
        "customer_profile.lookup",
        "product_catalogue.lookup",
        "conflict_check.search",
        "kyc_bo.lookup",
        "aml_record_store.record_assessment",
        "engagement_letter.draft",
        "engagement_letter.send",
        "engagement_letter.record_decline",
        "engagement_letter.route_manual_review",
        "attitude_to_risk.profile",
        "capacity_for_loss.assess",
        "platform_research.run",
        "suitability_report.draft",
        "suitability_report.issue",
        "suitability_report.record_decline",
        "suitability_report.route_manual_review"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "read",
        "propose",
        "write"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "arguments": {
      "type": "object"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
