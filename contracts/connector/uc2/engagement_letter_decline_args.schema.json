{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/uc2/engagement_letter_decline_args.schema.json",
  "title": "EngagementLetterDeclineArgs",
  "description": "Arguments accepted by the UC2 sandbox-engagement-letter-store connector when recording a decline-to-act outcome. The connector stores only safe refs and bounded reason categories at the port boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "legal_intake_ref",
    "engagement_decision_ref",
    "decline_ref",
    "decline_reason_category",
    "decline_summary_ref",
    "routing_policy_ref",
    "conduct_hook_refs"
  ],
  "properties": {
    "legal_intake_ref": {
      "type": "string",
      "pattern": "^legal_intake_[A-Za-z0-9_-]+$"
    },
    "engagement_decision_ref": {
      "type": "string",
      "pattern": "^engagement_decision_[A-Za-z0-9_-]+$"
    },
    "decline_ref": {
      "type": "string",
      "pattern": "^decline_[A-Za-z0-9_-]+$"
    },
    "decline_reason_category": {
      "type": "string",
      "enum": [
        "own_interest_conflict",
        "client_conflict_blocked",
        "confidentiality_risk_blocked",
        "aml_blocked",
        "cdd_incomplete",
        "unclear_prospective_client",
        "authority_uncertain",
        "outside_scope",
        "manual_decision"
      ]
    },
    "conflict_determination_ref": {
      "type": "string",
      "pattern": "^conflict_determination_[A-Za-z0-9_-]+$"
    },
    "aml_risk_assessment_ref": {
      "type": "string",
      "pattern": "^aml_risk_[A-Za-z0-9_-]+$"
    },
    "decline_summary_ref": {
      "type": "string",
      "pattern": "^decline_summary_[A-Za-z0-9_-]+$"
    },
    "routing_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    },
    "conduct_hook_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^conduct_[A-Za-z0-9_.:-]+$"
      }
    }
  }
}
