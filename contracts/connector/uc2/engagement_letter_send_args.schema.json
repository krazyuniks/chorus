{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/uc2/engagement_letter_send_args.schema.json",
  "title": "EngagementLetterSendArgs",
  "description": "Arguments accepted by the UC2 sandbox-engagement-letter-store connector for approval-gated engagement-letter send. The payload binds the exact draft, approval package, conflict / AML refs, and conduct-hook refs without carrying letter text, email addresses, or raw client data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "legal_intake_ref",
    "engagement_letter_ref",
    "engagement_decision_ref",
    "approval_package_ref",
    "send_instruction_ref",
    "prospective_client_ref",
    "matter_scope_ref",
    "conflict_determination_ref",
    "aml_risk_assessment_ref",
    "cdd_record_ref",
    "send_channel_category",
    "send_policy_ref",
    "conduct_hook_refs"
  ],
  "properties": {
    "legal_intake_ref": {
      "type": "string",
      "pattern": "^legal_intake_[A-Za-z0-9_-]+$"
    },
    "engagement_letter_ref": {
      "type": "string",
      "pattern": "^engagement_letter_[A-Za-z0-9_-]+$"
    },
    "engagement_decision_ref": {
      "type": "string",
      "pattern": "^engagement_decision_[A-Za-z0-9_-]+$"
    },
    "approval_package_ref": {
      "type": "string",
      "pattern": "^approval_[A-Za-z0-9_-]+$"
    },
    "send_instruction_ref": {
      "type": "string",
      "pattern": "^send_instruction_[A-Za-z0-9_-]+$"
    },
    "prospective_client_ref": {
      "type": "string",
      "pattern": "^prospective_client_[A-Za-z0-9_-]+$"
    },
    "matter_scope_ref": {
      "type": "string",
      "pattern": "^mscope_[A-Za-z0-9_-]+$"
    },
    "conflict_determination_ref": {
      "type": "string",
      "pattern": "^conflict_determination_[A-Za-z0-9_-]+$"
    },
    "aml_risk_assessment_ref": {
      "type": "string",
      "pattern": "^aml_risk_[A-Za-z0-9_-]+$"
    },
    "cdd_record_ref": {
      "type": "string",
      "pattern": "^cdd_record_[A-Za-z0-9_-]+$"
    },
    "send_channel_category": {
      "type": "string",
      "enum": [
        "email",
        "portal",
        "manual_capture"
      ]
    },
    "send_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    },
    "conduct_hook_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^conduct_[A-Za-z0-9_.:-]+$"
      }
    }
  }
}
