{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/uc3/suitability_report_decline_args.schema.json",
  "title": "SuitabilityReportDeclineArgs",
  "description": "Arguments accepted by the UC3 sandbox-suitability-report-store connector when recording an advice-service decline or unsuitable outcome. The payload stores bounded reason categories and safe refs only; raw client narratives and report prose stay outside the connector port payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "advice_enquiry_ref",
    "suitability_conclusion_ref",
    "decline_ref",
    "decline_reason_category",
    "decline_summary_ref",
    "routing_policy_ref",
    "conduct_hook_refs"
  ],
  "properties": {
    "advice_enquiry_ref": {
      "type": "string",
      "pattern": "^advice_enquiry_[A-Za-z0-9_-]+$"
    },
    "suitability_conclusion_ref": {
      "type": "string",
      "pattern": "^suitability_conclusion_[A-Za-z0-9_-]+$"
    },
    "decline_ref": {
      "type": "string",
      "pattern": "^decline_[A-Za-z0-9_-]+$"
    },
    "platform_research_ref": {
      "type": "string",
      "pattern": "^platform_research_[A-Za-z0-9_-]+$"
    },
    "capacity_for_loss_ref": {
      "type": "string",
      "pattern": "^capacity_for_loss_[A-Za-z0-9_-]+$"
    },
    "decline_reason_category": {
      "type": "string",
      "enum": [
        "out_of_scope_advice",
        "insufficient_necessary_information",
        "unsuitable_objective",
        "capacity_for_loss_blocked",
        "negative_target_market",
        "product_universe_defect",
        "vulnerability_support_unresolved",
        "manual_adviser_decision"
      ]
    },
    "decline_summary_ref": {
      "type": "string",
      "pattern": "^decline_summary_[A-Za-z0-9_-]+$"
    },
    "routing_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    },
    "conduct_hook_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^conduct_[A-Za-z0-9_.:-]+$"
      }
    }
  }
}
