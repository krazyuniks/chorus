{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/connector/ticket_duplicate_case_lookup_args.schema.json",
  "title": "TicketDuplicateCaseLookupArgs",
  "description": "Contract-only arguments for future local duplicate ticket lookup using safe refs and bounded categories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_ref",
    "account_ref",
    "product_ref",
    "severity_category",
    "status_categories",
    "duplicate_scope_category",
    "lookup_policy_ref"
  ],
  "properties": {
    "request_ref": {
      "type": "string",
      "pattern": "^req_[A-Za-z0-9_-]+$"
    },
    "account_ref": {
      "type": "string",
      "pattern": "^acct_[A-Za-z0-9_-]+$"
    },
    "product_ref": {
      "type": "string",
      "pattern": "^prod_[A-Za-z0-9_-]+$"
    },
    "case_ref": {
      "type": "string",
      "pattern": "^case_[A-Za-z0-9_-]+$"
    },
    "severity_category": {
      "type": "string",
      "enum": [
        "sev_low",
        "sev_medium",
        "sev_high",
        "sev_critical"
      ]
    },
    "status_categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "new",
          "open",
          "pending_customer",
          "pending_internal",
          "resolved",
          "closed",
          "escalated"
        ]
      }
    },
    "duplicate_scope_category": {
      "type": "string",
      "enum": [
        "same_account_product_open",
        "same_account_any_product_open",
        "same_product_recently_resolved"
      ]
    },
    "lookup_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    }
  }
}
