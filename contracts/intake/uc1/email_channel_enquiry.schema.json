{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/intake/uc1/email_channel_enquiry.schema.json",
  "x-subject": "chorus.uc1.email-channel-enquiry.v1-value",
  "title": "EmailChannelEnquiry",
  "description": "Inbound enquiry payload produced by the UC1 `email-channel` intake adapter from a broker firm's enquiries mailbox. Validated at the intake port before the UC1 enquiry-qualification workflow accepts the enquiry. The mailpit SMTP path is the local-sandbox realisation of this adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "enquiry_id",
    "tenant_id",
    "correlation_id",
    "channel",
    "adapter_id",
    "message_id",
    "received_at",
    "from_address",
    "to_recipients",
    "subject",
    "body_text",
    "message_headers",
    "attachments_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "enquiry_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "channel": {
      "type": "string",
      "const": "email"
    },
    "adapter_id": {
      "type": "string",
      "const": "email-channel"
    },
    "message_id": {
      "type": "string",
      "minLength": 3,
      "description": "Email Message-ID header value; channel idempotency key."
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "email"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "pattern": "^[^@\\s]+@[^@\\s]+$"
        }
      }
    },
    "to_recipients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[^@\\s]+@[^@\\s]+$"
      }
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "body_text": {
      "type": "string",
      "minLength": 1
    },
    "message_headers": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "attachments_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "filename",
          "content_type",
          "size_bytes"
        ],
        "properties": {
          "filename": {
            "type": "string"
          },
          "content_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
