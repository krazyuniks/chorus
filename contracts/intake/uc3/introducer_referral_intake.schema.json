{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/intake/uc3/introducer_referral_intake.schema.json",
  "x-subject": "chorus.uc3.introducer-referral-intake.v1-value",
  "title": "IntroducerReferralIntake",
  "description": "Inbound UC3 independent-financial-advice payload produced by the `introducer-referral-channel` adapter. Referral narratives, client contact details, authority evidence, platform account details, and attachments stay inside intake storage; this contract carries only safe refs, bounded categories, summaries, and provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "advice_enquiry_id",
    "tenant_id",
    "correlation_id",
    "channel",
    "adapter_id",
    "referral_id",
    "received_at",
    "source_payload_ref",
    "introducer_ref",
    "introducer_contact_ref",
    "referral_summary",
    "advice_need_categories",
    "support_need_categories",
    "attachments_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "advice_enquiry_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "channel": {
      "type": "string",
      "const": "introducer-referral-channel"
    },
    "adapter_id": {
      "type": "string",
      "const": "introducer-referral-channel"
    },
    "referral_id": {
      "type": "string",
      "pattern": "^ifa_referral_[A-Za-z0-9_-]+$",
      "description": "Introducer referral identifier; channel idempotency key."
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_payload_ref": {
      "type": "string",
      "pattern": "^source_payload_[A-Za-z0-9_-]+$"
    },
    "introducer_ref": {
      "type": "string",
      "pattern": "^introducer_[A-Za-z0-9_-]+$"
    },
    "introducer_contact_ref": {
      "type": "string",
      "pattern": "^contact_[A-Za-z0-9_-]+$"
    },
    "prospective_retail_client_ref": {
      "type": "string",
      "pattern": "^prospective_client_[A-Za-z0-9_-]+$"
    },
    "authority_evidence_ref": {
      "type": "string",
      "pattern": "^source_payload_[A-Za-z0-9_-]+$"
    },
    "referral_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "advice_need_categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "isa_investment",
          "pension_consolidation",
          "regular_investment",
          "retirement_planning",
          "portfolio_review",
          "cash_versus_investment",
          "inheritance_investment",
          "other"
        ]
      }
    },
    "product_or_platform_hint_refs": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^hint_[A-Za-z0-9_-]+$"
      }
    },
    "support_need_categories": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "communication_adjustment",
          "third_party_authority",
          "financial_difficulty",
          "bereavement",
          "health_marker",
          "low_capability",
          "none_disclosed",
          "unknown"
        ]
      }
    },
    "attachments_summary": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachment_ref",
          "document_category",
          "content_type",
          "size_bytes",
          "sha256"
        ],
        "properties": {
          "attachment_ref": {
            "type": "string",
            "pattern": "^attachment_[A-Za-z0-9_-]+$"
          },
          "document_category": {
            "type": "string",
            "enum": [
              "fact_find",
              "pension_statement",
              "investment_statement",
              "platform_summary",
              "authority_evidence",
              "support_need_evidence",
              "other"
            ]
          },
          "content_type": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
