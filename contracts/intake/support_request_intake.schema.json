{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/intake/support_request_intake.schema.json",
  "x-subject": "chorus.support-request-intake.v1-value",
  "title": "SupportRequestIntake",
  "description": "Contract-only support request intake payload for future local Support Desk Triage workflows using safe refs and bounded categories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_ref",
    "tenant_id",
    "correlation_id",
    "source_ref",
    "received_at",
    "intake_channel_category",
    "account_ref",
    "product_ref",
    "severity_hint_category",
    "request_status_category",
    "redacted_summary_ref",
    "idempotency_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_ref": {
      "type": "string",
      "pattern": "^req_[A-Za-z0-9_-]+$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "source_ref": {
      "type": "string",
      "pattern": "^source_[A-Za-z0-9_-]+$"
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "intake_channel_category": {
      "type": "string",
      "enum": [
        "email_alias",
        "portal",
        "chat_export",
        "api_fixture",
        "manual_fixture"
      ]
    },
    "account_ref": {
      "type": "string",
      "pattern": "^acct_[A-Za-z0-9_-]+$"
    },
    "product_ref": {
      "type": "string",
      "pattern": "^prod_[A-Za-z0-9_-]+$"
    },
    "case_ref": {
      "type": "string",
      "pattern": "^case_[A-Za-z0-9_-]+$"
    },
    "severity_hint_category": {
      "type": "string",
      "enum": [
        "sev_low",
        "sev_medium",
        "sev_high",
        "sev_critical",
        "unknown"
      ]
    },
    "request_status_category": {
      "type": "string",
      "enum": [
        "new",
        "open",
        "pending_customer",
        "pending_internal",
        "resolved",
        "closed",
        "escalated"
      ]
    },
    "redacted_summary_ref": {
      "type": "string",
      "pattern": "^summary_[A-Za-z0-9_-]+$"
    },
    "attachment_refs": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^att_[A-Za-z0-9_-]+$"
      }
    },
    "idempotency_ref": {
      "type": "string",
      "pattern": "^idem_[A-Za-z0-9_-]+$"
    },
    "routing_policy_ref": {
      "type": "string",
      "pattern": "^policy_[A-Za-z0-9_-]+$"
    }
  }
}
