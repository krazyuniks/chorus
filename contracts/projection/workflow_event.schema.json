{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/projection/workflow_event.schema.json",
  "x-subject": "chorus.workflow.events.v1-value",
  "title": "WorkflowEvent",
  "description": "Schema-governed workflow event emitted through the transactional outbox to Redpanda. The shape is use-case-agnostic: `workflow_type` names the use-case workflow on the spine, `step` carries the workflow's typed-step identifier, and the rest is correlation / sequencing / payload data shared across every use case.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "correlation_id",
    "workflow_id",
    "workflow_type",
    "sequence",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "enquiry.received",
        "workflow.started",
        "workflow.step.started",
        "workflow.step.completed",
        "workflow.completed",
        "workflow.escalated",
        "workflow.failed"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "uc1_enquiry_qualification"
      ]
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "The subject the workflow operates on (UC1: enquiry id)."
    },
    "subject_ref": {
      "type": "string",
      "pattern": "^enq_[A-Za-z0-9_-]+$",
      "description": "Subject reference in the use case's ubiquitous language."
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "step": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow step identifier declared by the use case's WorkflowDefinition."
    },
    "payload": {
      "type": "object"
    }
  }
}
