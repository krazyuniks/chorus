{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/llm_provider/support_agent_io.schema.json",
  "title": "SupportAgentIO",
  "description": "Contract-only request and result envelope for future Support Desk Triage agent tasks using safe refs and bounded categories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "tenant_id",
    "correlation_id",
    "workflow_id",
    "workflow_type",
    "agent_role",
    "task_kind",
    "input_refs",
    "expected_output_contract",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_type": {
      "type": "string",
      "const": "support_triage"
    },
    "agent_role": {
      "type": "string",
      "enum": [
        "support_classifier",
        "support_context_researcher",
        "support_resolution_planner",
        "support_drafter",
        "support_validator"
      ]
    },
    "task_kind": {
      "type": "string",
      "enum": [
        "support_classification",
        "support_context_lookup",
        "support_resolution_plan",
        "support_response_draft",
        "support_validation"
      ]
    },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_ref",
        "account_ref",
        "product_ref"
      ],
      "properties": {
        "request_ref": {
          "type": "string",
          "pattern": "^req_[A-Za-z0-9_-]+$"
        },
        "case_ref": {
          "type": "string",
          "pattern": "^case_[A-Za-z0-9_-]+$"
        },
        "account_ref": {
          "type": "string",
          "pattern": "^acct_[A-Za-z0-9_-]+$"
        },
        "product_ref": {
          "type": "string",
          "pattern": "^prod_[A-Za-z0-9_-]+$"
        },
        "redacted_summary_ref": {
          "type": "string",
          "pattern": "^summary_[A-Za-z0-9_-]+$"
        },
        "prior_invocation_refs": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "pattern": "^inv_[A-Za-z0-9_-]+$"
          }
        }
      }
    },
    "expected_output_contract": {
      "type": "string",
      "const": "contracts/llm_provider/support_agent_io.schema.json"
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "recommended_next_step",
        "verdict_category",
        "severity_category",
        "case_status_category",
        "output_refs"
      ],
      "properties": {
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recommended_next_step": {
          "type": "string",
          "enum": [
            "continue",
            "redraft",
            "escalate",
            "propose_only",
            "complete",
            "reject"
          ]
        },
        "verdict_category": {
          "type": "string",
          "enum": [
            "triage_continue",
            "needs_context",
            "needs_redraft",
            "propose_response",
            "propose_case_update",
            "escalate_to_human",
            "reject_as_unsupported"
          ]
        },
        "severity_category": {
          "type": "string",
          "enum": [
            "sev_low",
            "sev_medium",
            "sev_high",
            "sev_critical"
          ]
        },
        "case_status_category": {
          "type": "string",
          "enum": [
            "new",
            "open",
            "pending_customer",
            "pending_internal",
            "resolved",
            "closed",
            "escalated"
          ]
        },
        "resolution_category": {
          "type": "string",
          "enum": [
            "known_answer",
            "needs_account_review",
            "needs_product_review",
            "duplicate_case",
            "requires_human_escalation"
          ]
        },
        "output_refs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "request_ref": {
              "type": "string",
              "pattern": "^req_[A-Za-z0-9_-]+$"
            },
            "case_ref": {
              "type": "string",
              "pattern": "^case_[A-Za-z0-9_-]+$"
            },
            "resolution_plan_ref": {
              "type": "string",
              "pattern": "^plan_[A-Za-z0-9_-]+$"
            },
            "response_draft_ref": {
              "type": "string",
              "pattern": "^response_[A-Za-z0-9_-]+$"
            },
            "case_update_ref": {
              "type": "string",
              "pattern": "^caseupd_[A-Za-z0-9_-]+$"
            },
            "validation_ref": {
              "type": "string",
              "pattern": "^validation_[A-Za-z0-9_-]+$"
            }
          }
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "pattern": "^evidence_[A-Za-z0-9_-]+$"
          }
        }
      }
    }
  }
}
