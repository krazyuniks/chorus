{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/llm_provider/uc3_agent_io.schema.json",
  "title": "Uc3AgentIO",
  "description": "Structured request and result envelope for UC3 independent-financial-advice suitability agent tasks dispatched through the LLM provider port.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "tenant_id",
    "correlation_id",
    "workflow_id",
    "agent_role",
    "task_kind",
    "input",
    "expected_output_contract",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_role": {
      "type": "string",
      "enum": [
        "advice_scope_classifier",
        "fact_find_summariser",
        "risk_profile_assessor",
        "consumer_duty_support_assessor",
        "suitability_decider"
      ]
    },
    "task_kind": {
      "type": "string",
      "enum": [
        "uc3_advice_scope_classification",
        "uc3_fact_find_summary",
        "uc3_risk_profile_assessment",
        "uc3_consumer_duty_support_assessment",
        "uc3_suitability_conclusion"
      ]
    },
    "input": {
      "type": "object"
    },
    "expected_output_contract": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "confidence",
        "structured_data",
        "recommended_next_step",
        "rationale",
        "citations"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "structured_data": {
          "type": "object"
        },
        "recommended_next_step": {
          "type": "string",
          "enum": [
            "continue",
            "manual_review",
            "fact_find_incomplete",
            "approval_required",
            "escalate"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "reference"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "reference": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
