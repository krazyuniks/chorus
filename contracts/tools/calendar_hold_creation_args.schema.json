{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/tools/calendar_hold_creation_args.schema.json",
  "title": "CalendarHoldCreationArgs",
  "description": "Contract-only arguments for creating one local sandbox calendar hold after Tool Gateway approval and idempotency checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "calendar_ref",
    "hold_ref",
    "slot_ref",
    "event_uid_ref",
    "starts_at",
    "ends_at",
    "meeting_type",
    "participant_refs",
    "summary_category",
    "busy_status"
  ],
  "properties": {
    "calendar_ref": {
      "type": "string",
      "pattern": "^cal_[A-Za-z0-9_-]+$"
    },
    "hold_ref": {
      "type": "string",
      "pattern": "^hold_[A-Za-z0-9_-]+$"
    },
    "slot_ref": {
      "type": "string",
      "pattern": "^slot_[A-Za-z0-9_-]+$"
    },
    "event_uid_ref": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "starts_at": {
      "type": "string",
      "format": "date-time"
    },
    "ends_at": {
      "type": "string",
      "format": "date-time"
    },
    "meeting_type": {
      "type": "string",
      "enum": [
        "lighthouse_follow_up",
        "discovery_call",
        "qualification_review"
      ]
    },
    "participant_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^participant_[A-Za-z0-9_-]+$"
      }
    },
    "summary_category": {
      "type": "string",
      "enum": [
        "lead_follow_up",
        "proposal_review",
        "internal_review"
      ]
    },
    "busy_status": {
      "type": "string",
      "enum": [
        "busy",
        "tentative"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "busy_only"
      ]
    }
  }
}
