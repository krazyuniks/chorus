{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/eval/eval_fixture.schema.json",
  "title": "EvalFixture",
  "description": "Input scenario and expected outcome category for an invariant-based eval run (ADR 0019). Path-enumeration fields retired in R3 G; the invariant suite asserts the audit/transcript/projection shape directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "name",
    "workflow_type",
    "scenario",
    "input",
    "expected"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "uc1_enquiry_qualification"
      ]
    },
    "scenario": {
      "type": "string",
      "description": "Which branch the recorded-replay adapter exercises for this fixture.",
      "enum": [
        "happy_path",
        "deeper_context",
        "validator_redraft",
        "retry_exhaustion"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id"
      ],
      "properties": {
        "email_fixture_path": {
          "type": "string",
          "minLength": 1
        },
        "enquiry_fixture_ref": {
          "type": "string",
          "pattern": "^fixture_[A-Za-z0-9_-]+$"
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome_category"
      ],
      "properties": {
        "outcome_category": {
          "type": "string",
          "description": "Final disposition the scenario should reach.",
          "enum": [
            "propose",
            "escalate",
            "dlq"
          ]
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
