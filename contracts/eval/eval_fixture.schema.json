{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/eval/eval_fixture.schema.json",
  "title": "EvalFixture",
  "description": "Input scenario and expected outcome category for an invariant-based eval run (ADR 0019). Path-enumeration fields retired in R3 G; the invariant suite asserts the audit/transcript/projection shape directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "name",
    "workflow_type",
    "scenario",
    "input",
    "expected"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "workflow_type": {
      "type": "string",
      "description": "Workflow family on the shared spine for UC1, UC2, or UC3 eval fixtures.",
      "enum": [
        "uc1_enquiry_qualification",
        "uc2_legal_services_intake_conflict_check",
        "uc3_ifa_suitability_intake"
      ]
    },
    "scenario": {
      "type": "string",
      "description": "Use-case-owned scenario id for eval playback.",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id"
      ],
      "properties": {
        "source_fixture_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the synthetic intake or subject fixture for any use case."
        },
        "subject_fixture_ref": {
          "type": "string",
          "pattern": "^fixture_[A-Za-z0-9_-]+$",
          "description": "Use-case-neutral synthetic root-subject fixture reference."
        },
        "email_fixture_path": {
          "type": "string",
          "minLength": 1,
          "description": "Compatibility field for the current UC1 email fixtures."
        },
        "enquiry_fixture_ref": {
          "type": "string",
          "pattern": "^fixture_[A-Za-z0-9_-]+$",
          "description": "Compatibility field for UC1 enquiry refs."
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome_category"
      ],
      "properties": {
        "outcome_category": {
          "type": "string",
          "description": "Architecture-level final disposition the scenario should reach.",
          "enum": [
            "propose",
            "escalate",
            "dlq"
          ]
        },
        "use_case_outcome": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Optional use-case-domain outcome label for conduct and replay comparison."
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
