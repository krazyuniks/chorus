{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/eval/eval_fixture.schema.json",
  "title": "EvalFixture",
  "description": "Trace/eval fixture expectations for a Lighthouse workflow run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "name",
    "phase",
    "input",
    "expected"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "1A",
        "1B"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "email_fixture_path",
        "tenant_id"
      ],
      "properties": {
        "email_fixture_path": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_path",
        "final_outcome",
        "allowed_tool_actions",
        "blocked_tool_actions",
        "max_cost_usd",
        "max_latency_ms",
        "required_audit_fields",
        "required_event_types"
      ],
      "properties": {
        "workflow_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "final_outcome": {
          "type": "string",
          "enum": [
            "send",
            "propose",
            "escalate",
            "reject"
          ]
        },
        "allowed_tool_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_tool_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 1
        },
        "required_audit_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "required_event_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
