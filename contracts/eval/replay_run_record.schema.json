{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/eval/replay_run_record.schema.json",
  "title": "ReplayRunRecord",
  "description": "Replay-eval evidence record linking one captured invocation/transcript to an alternate provider route, comparator status, safe lineage refs, and token/cost/latency metrics. This record stores refs and bounded summaries only; raw prompts, raw provider outputs, credentials, and customer content remain outside this surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "replay_run_id",
    "tenant_id",
    "correlation_id",
    "workflow_id",
    "original",
    "alternate",
    "lineage",
    "comparator",
    "metrics",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "replay_run_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "pattern": "^tenant_[a-z0-9_]+$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "original": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invocation_id",
        "transcript_id",
        "runtime_route_id",
        "provider_id",
        "model_id",
        "adapter_version",
        "parameters"
      ],
      "properties": {
        "invocation_id": {
          "type": "string",
          "format": "uuid"
        },
        "transcript_id": {
          "type": "string",
          "format": "uuid"
        },
        "runtime_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "provider_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "alternate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_route_id",
        "provider_id",
        "model_id",
        "adapter_version",
        "parameters"
      ],
      "properties": {
        "runtime_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "provider_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_role",
        "task_kind",
        "prompt_reference",
        "prompt_hash",
        "response_schema_name",
        "response_schema_contract_ref",
        "response_schema_hash"
      ],
      "properties": {
        "agent_role": {
          "type": "string",
          "enum": [
            "advice_scope_classifier",
            "classifier",
            "conflict_analyst",
            "consumer_duty_support_assessor",
            "context_gatherer",
            "engagement_decider",
            "fact_find_summariser",
            "legal_matter_classifier",
            "legal_party_extractor",
            "qualifier",
            "request_drafter",
            "risk_profile_assessor",
            "suitability_decider",
            "validator"
          ]
        },
        "task_kind": {
          "type": "string",
          "minLength": 1
        },
        "policy_snapshot_ref": {
          "type": "string",
          "pattern": "^policy_snapshot:[A-Za-z0-9_.:-]+$"
        },
        "prompt_reference": {
          "type": "string",
          "minLength": 1
        },
        "prompt_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "response_schema_name": {
          "type": "string",
          "minLength": 1
        },
        "response_schema_contract_ref": {
          "type": "string",
          "minLength": 1
        },
        "response_schema_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "route_version_ref": {
          "type": "string",
          "minLength": 1
        },
        "provider_catalogue_id": {
          "type": "string",
          "pattern": "^provider-catalogue\\.[A-Za-z0-9_.-]+$"
        },
        "eval_fixture_ref": {
          "type": "string",
          "minLength": 1
        },
        "transcript_source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "comparator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "status",
        "result"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped",
            "error"
          ]
        },
        "result": {
          "type": "object",
          "description": "Safe comparator payload with reason codes and changed field names."
        },
        "safe_error_reason": {
          "type": "string",
          "minLength": 1
        },
        "safe_skipped_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original",
        "alternate",
        "delta"
      ],
      "properties": {
        "original": {
          "$ref": "#/$defs/run_metrics"
        },
        "alternate": {
          "$ref": "#/$defs/run_metrics"
        },
        "delta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cost_amount_usd",
            "latency_ms",
            "token_usage"
          ],
          "properties": {
            "cost_amount_usd": {
              "type": "number"
            },
            "latency_ms": {
              "type": "integer"
            },
            "token_usage": {
              "$ref": "#/$defs/token_usage_delta"
            }
          }
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "run_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cost_amount_usd",
        "cost_currency",
        "latency_ms",
        "token_usage"
      ],
      "properties": {
        "cost_amount_usd": {
          "type": "number",
          "minimum": 0
        },
        "cost_currency": {
          "type": "string",
          "const": "USD"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "$ref": "#/$defs/token_usage"
        }
      }
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "token_usage_delta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": {
          "type": "integer"
        },
        "completion_tokens": {
          "type": "integer"
        },
        "total_tokens": {
          "type": "integer"
        }
      }
    }
  }
}
