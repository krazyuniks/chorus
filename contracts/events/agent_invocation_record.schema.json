{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.local/contracts/events/agent_invocation_record.schema.json",
  "x-subject": "chorus.agent-invocations.v1-value",
  "title": "AgentInvocationRecord",
  "description": "Decision-trail record captured by the Agent Runtime for every governed agent invocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invocation_id",
    "correlation_id",
    "workflow_id",
    "tenant_id",
    "agent",
    "model_route",
    "input_summary",
    "output_summary",
    "justification",
    "outcome",
    "tool_call_ids",
    "cost",
    "duration_ms",
    "started_at",
    "completed_at",
    "contract_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "invocation_id": {
      "type": "string",
      "format": "uuid"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cor_[A-Za-z0-9_-]+$"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "role",
        "version",
        "lifecycle_state",
        "prompt_reference",
        "prompt_hash"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "intake",
            "researcher",
            "qualifier",
            "drafter",
            "validator"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "draft",
            "approved",
            "deprecated",
            "disabled"
          ]
        },
        "prompt_reference": {
          "type": "string",
          "minLength": 1
        },
        "prompt_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "model_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "task_kind",
        "budget_cap_usd"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "task_kind": {
          "type": "string",
          "minLength": 1
        },
        "budget_cap_usd": {
          "type": "number",
          "minimum": 0
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "input_summary": {
      "type": "string",
      "minLength": 1
    },
    "output_summary": {
      "type": "string",
      "minLength": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "escalated"
      ]
    },
    "tool_call_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "USD"
        }
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
