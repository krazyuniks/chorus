# Normalise line endings and binary types across platforms.

* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.zsh   text eol=lf
*.bash  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.db    binary
*.sqlite binary
